{
  "name": "quality-gate-pipeline",
  "version": "1.0.2",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "bash scripts/verify.sh",
    "smoke": "bash scripts/verify.sh",
    "start:mcp": "node --import tsx server.ts",
